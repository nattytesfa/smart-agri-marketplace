# dummy strings will be replaced with actual values in production. Do not commit sensitive information to version control.
# ask your team for the actual values and replace them in your local .env file.

# Node.js Express Server Port
PORT=4000
NODE_ENV=development

# Database (Supabase PostgreSQL Connection String)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Supabase Auth / API Keys (Get from Dashboard)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="ey..."

# Auth Secret for JWT verification
JWT_SECRET="your-super-secret-jwt-key"

# Telebirr Sandbox API Keys
TELEBIRR_API_KEY="your-telebirr-key"
TELEBIRR_MERCHANT_ID="your-merchant-id"

# CBE Birr Sandbox API Key
CBE_BIRR_API_KEY="your-cbe-key"

# Fayda National ID Sandbox Key
FAYDA_API_KEY="your-fayda-key"

# External Data APIs
NMIS_API_URL="https://api.nmis.gov.et"
NMA_API_KEY="your-nma-weather-key"
OPENWEATHER_API_KEY="your-openweather-key"

# SMS Gateway (for offline mode fallback notifications)
SMS_GATEWAY_API_KEY="your-sms-gateway-key"

# Google Maps (Admin Heatmaps/Backend Geo)
GOOGLE_MAPS_SERVER_KEY="your-gmaps-server-key"
